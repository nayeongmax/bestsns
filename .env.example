# ============================================
# DB 연동 방법: 이 파일을 .env 로 복사한 뒤 아래 값을 채우세요.
# (실제 비밀값은 이 파일에 넣지 말고 .env 에만 넣고, .env 는 Git에 커밋하지 마세요.)
# 배포 시 Netlify 대시보드 > Environment variables 에서 설정하세요.
# ============================================

# Supabase — 여기를 채우면 회원/주문/게시글/공지 등 모든 데이터가 DB에 저장됩니다.
# Supabase 대시보드: https://supabase.com/dashboard > 프로젝트 선택 > Settings > API
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 운영자(어드민) — 배포 시 반드시 다른 값으로 설정
# VITE_ADMIN_ID=your_admin_id
# VITE_ADMIN_PASSWORD=your_admin_password
# VITE_ADMIN_PANEL_PASSWORD=  # 없으면 VITE_ADMIN_PASSWORD 와 동일

# AI 컨설팅 (Gemini) — 발급: https://aistudio.google.com/apikey
# 로컬에서 AI 테스트: netlify dev 로 실행 후 사용
# GEMINI_API_KEY=your_gemini_api_key
